[
  {
    "title": "Vortex",
    "description": "Create and relax a magnetic vortex",
    "tags": ["vortex", "relax", "exchange", "demag"],
    "steps": [
      {
        "title": "Create Mesh",
        "code": "mesh = FDMesh(nx=100, ny=100, nz=10, dx=2e-9, dy=2e-9, dz=2e-9);"
      },
      {
        "title": "Create Simulation",
        "code": "sim = Sim(mesh; name=\"vortex\", driver=\"SD\")"
      },
      {
        "title": "Set Saturation Magnetization",
        "code": "set_Ms(sim, Cylinder(radius = 100e-9), 8e5)"
      },
      {
        "title": "Initialize Magnetization",
        "code": "init_m0(sim, vortex(p=1, c=-1))"
      },
      {
        "title": "Add Exchange Interaction",
        "code": "add_exch(sim, 1.3e-11)"
      },
      {
        "title": "Add Demagnetization",
        "code": "add_demag(sim)"
      },
      {
        "title": "Relax System",
        "code": "relax(sim; stopping_dmdt=0.01)"
      }
    ]
  },
  {
    "title": "Standard 4",
    "description": "Standard micromagnetic simulation with LLG dynamics",
    "tags": ["std4", "llg", "exchange", "demag", "zeeman", "dynamic"],
    "steps": [
      {
        "title": "Create Mesh",
        "code": "mesh = FDMesh(; nx=200, ny=50, nz=1, dx=2.5e-9, dy=2.5e-9, dz=3e-9);"
      },
      {
        "title": "Create Simulation",
        "code": "sim = Sim(mesh; name=\"std4\", driver=\"SD\")"
      },
      {
        "title": "Set Saturation Magnetization",
        "code": "set_Ms(sim, 8e5)"
      },
      {
        "title": "Initialize Magnetization",
        "code": "init_m0(sim, (1, 0.25, 0.1))"
      },
      {
        "title": "Add Exchange Interaction",
        "code": "A = 1.3e-11; # J/m\nadd_exch(sim, A)"
      },
      {
        "title": "Add Demagnetization",
        "code": "add_demag(sim)"
      },
      {
        "title": "Relax System",
        "code": "relax(sim; stopping_dmdt=0.01)"
      },
      {
        "title": "Set LLG driver",
        "code": "set_driver(sim; driver=\"LLG\", alpha=0.02, gamma=2.211e5)"
      },
      {
        "title": "Add Zeeman Interaction",
        "code": "add_zeeman(sim, (-24.6mT, 4.3mT, 0))"
      },
      {
        "title": "Run Simulation",
        "code": "run_sim(sim; steps=100, dt=1e-11, save_m_every=1)"
      }
    ]
  },
  {
    "title": "Ms Demo",
    "description": "Demonstration of Ms (saturation magnetization) settings",
    "tags": ["ms", "demo", "material"],
    "steps": [
      {
        "title": "Create Mesh",
        "code": "mesh = FDMesh(; nx=100, ny=100, nz=10, dx=2e-9, dy=2e-9, dz=2e-9);"
      },
      {
        "title": "Create Simulation",
        "code": "sim = Sim(mesh; name=\"Ms_demo\")"
      },
      {
        "title": "Set Ms (const)",
        "code": "set_Ms(sim, 8e5)"
      },
      {
        "title": "Set Ms (function)",
        "code": "function circular_Ms(x, y, z)\n    if x^2 + y^2 <= (50e-9)^2\n        return 8e5\n    end\n    return 0.0\nend"
      }
    ]
  },
  {
    "title": "Init M0 Demo",
    "description": "Demonstration of initial magnetization settings",
    "tags": ["m0", "demo", "initialization"],
    "steps": [
      {
        "title": "Create Mesh",
        "code": "mesh = FDMesh(; nx=100, ny=100, nz=10, dx=2e-9, dy=2e-9, dz=2e-9);"
      },
      {
        "title": "Create Simulation",
        "code": "sim = Sim(mesh; name=\"init_m0_demo\")"
      },
      {
        "title": "Set Ms (shape)",
        "code": "set_Ms(sim, Cylinder(radius = 100e-9), 8e5)"
      },
      {
        "title": "init_m0 (const)",
        "code": "init_m0(sim, (1, 0.25, 0.1))"
      },
      {
        "title": "init_m0 (function)",
        "code": "function init_fun(x, y, z)\n    r = sqrt(x^2 + y^2)\n    if r < 20e-9\n        return (0, 0, 1)\n    end\n    return (sin(pi*x/20e-9), 0, cos(pi*x/20e-9))\nend"
      }
    ]
  }
]